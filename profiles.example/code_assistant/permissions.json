{
  "version": "1.0",
  "defaultPolicy": "ask",
  "blacklist": {
    "tools": [],
    "patterns": [
      "rm -rf /*",
      "sudo *",
      "chmod 777 *",
      "curl * | bash",
      "wget * | bash"
    ],
    "arguments": {
      "cli_based_tool": {
        "command": ["rm -rf /", "sudo", "shutdown", "reboot", "mkfs", "dd if="]
      }
    }
  },
  "whitelist": {
    "tools": ["addTodo", "completeTodo", "listTodos"],
    "patterns": [
      "git *",
      "npm *",
      "python *",
      "pytest *",
      "ls *",
      "cat *",
      "grep *",
      "find *",
      "pwd",
      "echo *"
    ],
    "arguments": {}
  },
  "actor": {
    "type": "console",
    "timeout": 30
  }
}
